<%- layout('layouts/boilerplate') %>

<div class="container mt-5">
  <div class="row">
    <div class="col-md-12">
      <h2 class="mb-4">🛠️ Admin - All Bookings</h2>

      <% if (bookings && bookings.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover table-striped">
            <thead class="table-dark">
              <tr>
                <th>User</th>
                <th>Property</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Guests</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% bookings.forEach(booking => { %>
                <% if (booking.listing && booking.user) { %>
                <tr>
                  <td><strong><%= booking.user.username %></strong></td>
                  <td><a href="/listings/<%= booking.listing._id %>"><%= booking.listing.title %></a></td>
                  <td><%= new Date(booking.checkInDate).toLocaleDateString() %></td>
                  <td><%= new Date(booking.checkOutDate).toLocaleDateString() %></td>
                  <td><%= booking.guests %></td>
                  <td>KES <%= booking.totalPrice.toLocaleString() %></td>
                  <td>
                    <% if (booking.status === 'pending') { %>
                      <span class="badge bg-warning">⏳ Pending</span>
                    <% } else if (booking.status === 'approved') { %>
                      <span class="badge bg-success">✅ Approved</span>
                    <% } else { %>
                      <span class="badge bg-danger">❌ Rejected</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (booking.status === 'pending') { %>
                      <form action="/bookings/admin/approve/<%= booking._id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                      </form>
                      <form action="/bookings/admin/reject/<%= booking._id %>" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
                <% } %>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-info">
          <p>No bookings found.</p>
        </div>
      <% } %>

      <div class="mt-4">
        <a href="/" class="btn btn-secondary">← Back to Home</a>
      </div>
    </div>
  </div>
</div>
