<% layout("/layouts/boilerplate") %>

<body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen flex items-center justify-center">
  <div class="bg-white rounded-2xl shadow-lg max-w-md w-full p-8 md:p-10 transition-all duration-300">

    <a class="text-3xl text-black hover:text-orange-400" href="/"><i class="fa-solid fa-backward"></i></a>
    <!-- Profile Avatar -->
    <div class="flex flex-col items-center">
      <div class="relative">
        <img src="/profile-user.png" alt="Profile" class="w-32 h-32 rounded-full object-cover shadow-lg border-4 border-orange-500">
        <div class="absolute bottom-0 right-1 w-5 h-5 bg-green-500 rounded-full border-2 border-white"></div>
      </div>

      <!-- User Info -->
      <h1 class="mt-5 text-2xl font-bold text-gray-800">Welcome, <%= username %> 👋</h1>
      <p class="text-gray-500 mt-1">Registered Email</p>
      <p class="text-sm text-gray-700 font-medium"><%= email %></p>
    </div>

    <!-- Divider -->
    <div class="my-6 border-t border-gray-200"></div>

    <!-- Actions -->
    <div class="space-y-3">
      <div class="flex gap-2 justify-center">
        <a href="/report" class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-full shadow-md transition duration-300 text-sm">
          📊 Report
        </a>
        <% if (!currentUser || !currentUser.isAdmin) { %>
          <a href="/bookings/my-bookings" class="px-4 py-2 bg-purple-500 hover:bg-purple-600 text-white rounded-full shadow-md transition duration-300 text-sm">
            📦 My Bookings
          </a>
        <% } %>
      </div>
      <% if (currentUser && currentUser.isAdmin) { %>
      <div class="flex gap-2 justify-center">
        <a href="/bookings/admin/my-listing-bookings" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-full shadow-md transition duration-300 text-sm">
          📅 Listing Bookings
        </a>
        <a href="/coupons/admin/all-coupons" class="px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white rounded-full shadow-md transition duration-300 text-sm">
          🎟️ Coupons
        </a>
      </div>
      <% } %>
      <div class="flex gap-2 justify-center">
        <a href="/listings/newlist" class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-md transition duration-300 text-sm">
          ➕ New Listing
        </a>
        <a href="/logout" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-full shadow-md transition duration-300 text-sm">
          🔓 Logout
        </a>
      </div>
    </div>
  </div>
</body>
